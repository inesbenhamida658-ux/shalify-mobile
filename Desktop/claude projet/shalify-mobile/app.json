{
  "expo": {
    "name": "Shalify",
    "slug": "shalify-mobile",
    "owner": "shalifyapp",
    "version": "1.0.0",
    "sdkVersion": "54.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#13241A"
    },
    "scheme": "shalify",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.shalify.mobile",
      "infoPlist": {
        "NSFaceIDUsageDescription": "Shalify utilise Face ID pour déverrouiller ton compte en toute sécurité."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0F1F17"
      },
      "package": "app.shalify.mobile"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro",
      "output": "single"
    },
    "plugins": [
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Shalify utilise Face ID pour déverrouiller ton compte en toute sécurité."
        }
      ],
      "expo-secure-store"
    ],
    "experiments": {
      "baseUrl": "/app"
    },
    "extra": {
      "apiBaseUrl": "https://shalify.app",
      "eas": {
        "projectId": "07f15ed4-25b3-46e7-ad20-09e6c7f8e1a6"
      }
    }
  }
}

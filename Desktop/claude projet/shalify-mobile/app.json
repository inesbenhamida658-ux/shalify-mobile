{
  "expo": {
    "name": "Shalify",
    "slug": "shalify-mobile",
    "version": "1.0.0",
    "sdkVersion": "54.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FAF7F2"
    },
    "scheme": "shalify",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.shalify.mobile"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0F1F17"
      },
      "package": "app.shalify.mobile"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "extra": {
      "apiBaseUrl": "https://shalify.app",
      "eas": {
        "projectId": "cad894e2-41fe-44ff-9f4b-fa381432eebc"
      }
    }
  }
}

# Shalify Mobile — variables d'environnement
# Seules les variables EXPO_PUBLIC_ sont accessibles côté client
# Ne jamais committer de valeurs secrètes dans ce fichier

# URL de l'API (pas de secret, pointe vers le web app)
EXPO_PUBLIC_API_BASE_URL=https://shalify.app

# Paiement — fournisseur actif (ziina | none)
EXPO_PUBLIC_PAYMENT_PROVIDER=ziina

# Lien de paiement Ziina (page hébergée, public par nature, aucun secret)
EXPO_PUBLIC_ZIINA_PAYMENT_URL=https://pay.ziina.com/shalify

# PAS de secrets côté mobile — les clés Upstash, Resend, Admin
# sont uniquement dans Vercel Dashboard côté serveur
